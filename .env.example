# Auth OIDC / Google
# Para desarrollo local, configura la app OAuth con:
# Redirect URI: http://127.0.0.1:4173/auth/oidc/callback

TOPYKLY_SESSION_SECRET=change-this-long-random-secret
TOPYKLY_AUTH_PROVIDER_NAME=Google
TOPYKLY_OIDC_ISSUER=https://accounts.google.com
TOPYKLY_OIDC_CLIENT_ID=
TOPYKLY_OIDC_CLIENT_SECRET=
TOPYKLY_OIDC_SCOPE=openid profile email

# Cloudflare Turnstile anti-bots para login.
# Crear widget en Cloudflare Turnstile y copiar Site Key + Secret Key.
TOPYKLY_TURNSTILE_SITE_KEY=
TOPYKLY_TURNSTILE_SECRET_KEY=

# Confirmacion de registro por codigo de email con Resend (no se usa para iniciar sesion).
# El remitente debe pertenecer a un dominio verificado en Resend.
TOPYKLY_RESEND_API_KEY=
TOPYKLY_RESEND_FROM=TOPYKLY <acceso@topykly.com>
# Emails con acceso admin, separados por coma.
# TOPYKLY_ADMIN_EMAILS=admin@example.com

# Opcional para elegir una ruta persistente en VPS.
# TOPYKLY_DB_PATH=/var/lib/topykly/topykly.sqlite
# Contenido editorial inicial, solo para una base vacía. Las cuentas se muestran
# como perfiles editoriales ficticios y no se presentan como personas reales.
# TOPYKLY_SEED_DEMO_DATA=true

# Produccion detras de proxy, HTTPS o dominio propio.
# OBLIGATORIO en produccion: NODE_ENV=production. Sin esto el login local sin
# contraseña queda habilitado y los secretos de desafio usan un fallback efimero.
# Con NODE_ENV=production el servidor ademas se niega a arrancar sin TOPYKLY_SESSION_SECRET.
# NODE_ENV=production
# Activa TRUST_PROXY solo si el servidor recibe trafico desde un proxy que sobrescribe
# cf-connecting-ip/x-forwarded-for (por ejemplo Cloudflare, Nginx o Vercel).
# TOPYKLY_TRUST_PROXY=true
# Login local de desarrollo. En NODE_ENV=production siempre queda bloqueado.
# TOPYKLY_ALLOW_LOCAL_LOGIN=false
# Origen publico canonico del sitio. Ademas del callback OIDC, define las URLs
# absolutas de SEO (canonical, sitemap.xml) y los origenes aceptados en el
# chequeo anti-CSRF de peticiones de escritura.
# TOPYKLY_PUBLIC_ORIGIN=https://www.topykly.com
# TOPYKLY_COOKIE_SECURE=true
